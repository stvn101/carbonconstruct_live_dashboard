# CarbonConstruct Live Dashboard – Environment Variables
#
# Copy this file to .env.local for local development.
# Set these variables in your Vercel project dashboard for production.
#
# ─────────────────────────────────────────────────────────────────────────────
# CARBONCONSTRUCT_API_URL (required for live data)
#
#   Base URL of the CarbonConstruct API.
#   The dashboard backend will call the following endpoints on this base URL:
#
#     GET  {CARBONCONSTRUCT_API_URL}/dashboard
#          Returns: CarbonData JSON (totalSaved, activeProjects, efficiency,
#                   trend[], materials[], liveFeed[])
#          Auth:    Bearer token forwarded from the browser, or the server-side
#                   CARBONCONSTRUCT_API_KEY when no user token is present.
#
#     POST {CARBONCONSTRUCT_API_URL}/auth/signin
#          Body:    { "email": "...", "password": "..." }
#          Returns: { "token": "<jwt>" }
#
#   Leave this variable unset to run the dashboard with built-in mock data
#   (useful for UI development without a live backend).
# ─────────────────────────────────────────────────────────────────────────────
CARBONCONSTRUCT_API_URL=https://carbonconstruct.com.au/api

# ─────────────────────────────────────────────────────────────────────────────
# CARBONCONSTRUCT_API_KEY (optional)
#
#   A server-to-server API key used when fetching public/anonymous data
#   (i.e. when there is no authenticated user token in the request).
#   This key is never exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────
CARBONCONSTRUCT_API_KEY=your_api_key_here
